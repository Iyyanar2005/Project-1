@model IEnumerable<MyMvcApp.Models.Employee>

<h2>Employee List</h2>

<table class="table">
    <thead>
        <tr>
            <th>EmpID</th>
            <th>Name</th>
            <th>Salary</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Model)
        {
            <tr>
                <td>@emp.EmpID</td>
                <td>@emp.Name</td>
                <td>@emp.Salary</td>
            </tr>
        }
    </tbody>
</table>