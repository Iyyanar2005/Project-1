@model IEnumerable<MyMvcApp.Models.Employee>

<h2>Employee List</h2>

<form method="post" action="@Url.Action("Search", "Employee")">
    <input type="text" name="Name" placeholder="Enter Name" />
    <button type="submit">Search</button>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Salary</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Model)
        {
            <tr>
                <td>@emp.EmpID</td>
                <td>@emp.Name</td>
                <td>@emp.Salary</td>
            </tr>
        }
    </tbody>
</table>